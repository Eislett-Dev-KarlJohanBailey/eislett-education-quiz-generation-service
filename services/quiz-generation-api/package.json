{
  "name": "@services/quiz-generation-api",
  "version": "1.0.0",
  "description": "API for quiz generation: POST to queue, GET by id",
  "main": "dist/handler/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "package": "npm run build && esbuild src/handler/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js && cd dist && zip -r ../function.zip index.js",
    "deploy": "echo Deploying quiz-generation-api..."
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.975.0",
    "@aws-sdk/client-sqs": "^3.975.0",
    "@aws-sdk/lib-dynamodb": "^3.975.0",
    "jsonwebtoken": "^9.0.2",
    "aws-lambda": "^1.0.7"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.160",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.0.10",
    "esbuild": "^0.27.2",
    "typescript": "^5.9.3"
  }
}
